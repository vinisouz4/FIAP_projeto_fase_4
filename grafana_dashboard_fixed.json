{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Monitoramento da API FIAP Projeto Fase 4",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Status Geral",
      "type": "row"
    },

    {
      "id": 1,
      "title": "Modelo Carregado",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "OFFLINE", "color": "red" }, "1": { "text": "ONLINE", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 1 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [{ "expr": "model_loaded", "legendFormat": "Modelo", "refId": "A" }],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },

    {
      "id": 2,
      "title": "Total de Requisições",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["sum"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": 0 }] }
        }
      },
      "targets": [{ "expr": "sum(api_requests_total)", "legendFormat": "Total", "refId": "A" }],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },

    {
      "id": 3,
      "title": "Req/s (último 1min)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 50 }] }
        }
      },
      "targets": [{ "expr": "sum(rate(api_requests_total[1m]))", "legendFormat": "req/s", "refId": "A" }],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },

    {
      "id": 4,
      "title": "Memória (MB)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 512 }, { "color": "red", "value": 1024 }] }
        }
      },
      "targets": [{ "expr": "process_memory_mb", "legendFormat": "Memória", "refId": "A" }],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },

    {
      "id": 5,
      "title": "CPU (%)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 80 }] }
        }
      },
      "targets": [{ "expr": "process_cpu_percent", "legendFormat": "CPU", "refId": "A" }],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },

    {
      "id": 6,
      "title": "Erros (5xx)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["sum"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 1 }] }
        }
      },
      "targets": [{ "expr": "sum(api_requests_total{status_code=~\"5..\"})", "legendFormat": "Erros 5xx", "refId": "A" }],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Latência",
      "type": "row"
    },

    {
      "id": 7,
      "title": "Latência Média por Endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "expr": "rate(api_request_duration_seconds_sum[5m]) / rate(api_request_duration_seconds_count[5m])",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },

    {
      "id": 8,
      "title": "P50 / P95 / P99 — /predict",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(api_request_duration_seconds_bucket{endpoint=~\"/api/predict.*\"}[5m]))", "legendFormat": "P50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, rate(api_request_duration_seconds_bucket{endpoint=~\"/api/predict.*\"}[5m]))", "legendFormat": "P95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, rate(api_request_duration_seconds_bucket{endpoint=~\"/api/predict.*\"}[5m]))", "legendFormat": "P99", "refId": "C" }
      ],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "Requisições",
      "type": "row"
    },

    {
      "id": 9,
      "title": "Taxa de Requisições por Endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        { "expr": "rate(api_requests_total[1m])", "legendFormat": "{{method}} {{endpoint}} {{status_code}}", "refId": "A" }
      ],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },

    {
      "id": 10,
      "title": "Requisições em Andamento",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        { "expr": "api_requests_in_progress", "legendFormat": "{{method}} {{endpoint}}", "refId": "A" }
      ],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 103,
      "title": "Modelo — Predições",
      "type": "row"
    },

    {
      "id": 11,
      "title": "Predições por Direção (UP/DOWN/NEUTRAL)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        { "expr": "rate(model_predict_total[5m])", "legendFormat": "{{direction}} ({{confidence}})", "refId": "A" }
      ],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },

    {
      "id": 12,
      "title": "Latência de Inferência do Modelo",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(model_predict_duration_seconds_bucket[5m]))", "legendFormat": "P50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, rate(model_predict_duration_seconds_bucket[5m]))", "legendFormat": "P95", "refId": "B" }
      ],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },

    {
      "id": 13,
      "title": "Distribuição dos Retornos Previstos (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(model_predicted_return_pct_bucket[5m]))", "legendFormat": "Retorno P50 (%)", "refId": "A" },
        { "expr": "histogram_quantile(0.95, rate(model_predicted_return_pct_bucket[5m]))", "legendFormat": "Retorno P95 (%)", "refId": "B" }
      ],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "id": 104,
      "title": "Recursos do Sistema",
      "type": "row"
    },

    {
      "id": 14,
      "title": "Memória ao Longo do Tempo (MB)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 512 }, { "color": "red", "value": 1024 }] }
        }
      },
      "targets": [
        { "expr": "process_memory_mb", "legendFormat": "Memória RSS", "refId": "A" }
      ],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },

    {
      "id": 15,
      "title": "CPU ao Longo do Tempo (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 80 }] }
        }
      },
      "targets": [
        { "expr": "process_cpu_percent", "legendFormat": "CPU %", "refId": "A" }
      ],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    }

  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["fiap", "api", "ml"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "FIAP API — Monitoramento",
  "uid": "fiap-api-monitoring",
  "version": 1
}
